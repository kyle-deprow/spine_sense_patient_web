{
  "name": "spine-sense-patient-web",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "build:patient-app": "node scripts/build-patient-app-export.cjs",
    "copy:patient-app-export": "node scripts/copy-patient-app-export.cjs",
    "start": "node .next/standalone/server.js",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:voice": "playwright test --project=chromium-voice",
    "test:e2e:full-assessment": "PATIENT_WEB_INCLUDE_FULL_ASSESSMENT=true playwright test --grep @full-assessment",
    "test:e2e:full-assessment:stress": "PATIENT_WEB_INCLUDE_FULL_ASSESSMENT=true PATIENT_WEB_FULL_ASSESSMENT_STRESS=true playwright test --grep @full-assessment",
    "smoke:bundle": "node scripts/check-browser-bundle.cjs",
    "validate:local": "pnpm lint && pnpm type-check && pnpm test && pnpm build:patient-app && pnpm build && pnpm smoke:bundle",
    "test:e2e:verify": "node scripts/check-playwright-evidence.cjs",
    "release:validate": "pnpm validate:local && node scripts/check-playwright-evidence.cjs --release",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css,md}\""
  },
  "dependencies": {
    "ioredis": "^5.11.1",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@next/eslint-plugin-next": "^15.1.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  }
}
