BACKEND_INTERNAL_URL=http://localhost:8000
PATIENT_WEB_ALLOWED_ORIGINS=http://localhost:3000
PATIENT_WEB_CSRF_SECRET=replace-with-32-plus-byte-random-secret
PATIENT_WEB_AUDIT_ACTOR_SIGNING_CURRENT_KEY_ID=actor-key-2026-01
PATIENT_WEB_AUDIT_ACTOR_SIGNING_CURRENT_KEY=replace-with-independent-32-plus-byte-random-secret
# Set both previous values during a rotation window; otherwise leave both unset.
PATIENT_WEB_AUDIT_ACTOR_SIGNING_PREVIOUS_KEY_ID=
PATIENT_WEB_AUDIT_ACTOR_SIGNING_PREVIOUS_KEY=
PATIENT_WEB_PUBLIC_URL=http://localhost:3000
# Development-only override. Production and test always force Secure cookies.
PATIENT_WEB_COOKIE_SECURE=false
# E2E testing only — disables Secure cookie flag for local HTTP. NEVER set in production.
PATIENT_WEB_E2E_ALLOW_INSECURE_COOKIES=
# Exact storage origins only; wildcard origins are rejected at startup.
NEXT_PUBLIC_STORAGE_DOMAINS=https://patient-documents.example.test https://assets.example.test
PATIENT_WEB_LOCAL_MINIO_PUBLIC_ORIGIN=http://127.0.0.1:9000
# Explicit deployment class used to validate local versus HTTPS storage origins.
PATIENT_APP_ENVIRONMENT=development
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_BAA_CONFIRMED=false
