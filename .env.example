BACKEND_INTERNAL_URL=http://localhost:8000
PATIENT_WEB_ALLOWED_ORIGINS=http://localhost:3000
PATIENT_WEB_CSRF_SECRET=replace-with-32-plus-byte-random-secret
# Development-only override. Production and test always force Secure cookies.
PATIENT_WEB_COOKIE_SECURE=false
# E2E testing only — disables Secure cookie flag for local HTTP. NEVER set in production.
PATIENT_WEB_E2E_ALLOW_INSECURE_COOKIES=
NEXT_PUBLIC_STORAGE_DOMAINS=https://*.s3.amazonaws.com https://*.storage.googleapis.com
# DEV/TEST ONLY: when "true", the BFF allows the microphone
# (Permissions-Policy: microphone=(self)) so the patient web app can record
# voice. Gated on the var's presence (the BFF runs production-mode locally), so
# it must match the patient app's EXPO_PUBLIC_ENABLE_WEB_VOICE. NEVER set in
# production — patient web voice is disabled-by-policy (HIPAA PW-HIPAA-010).
EXPO_PUBLIC_ENABLE_WEB_VOICE=
